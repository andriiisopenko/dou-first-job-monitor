# Telegram Bot token from BotFather
TELEGRAM_BOT_TOKEN=1234567890:YOUR_BOT_TOKEN

# Chat ID where notifications will be sent
TELEGRAM_CHAT_ID=123456789

# DOU page to monitor
DOU_FIRST_JOB_URL=https://jobs.dou.ua/first-job/

# SQLite DB path
DATABASE_PATH=./data/vacancies.db

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Optional request timeout in ms
HTTP_TIMEOUT_MS=20000

# Send "monitor is alive" message at the start of every run
HEARTBEAT_EVERY_RUN=true

# Send summary after every run
SUMMARY_EVERY_RUN=true

# Include debug info for skipped new vacancies in summary
DEBUG_MODE=false